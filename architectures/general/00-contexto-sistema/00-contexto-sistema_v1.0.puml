@startuml
title Context Diagram - Distributed Architecture

actor "Mobile User" as USER_M
actor "Administrator" as ADMIN
actor "External System" as EXT

package "Sistema de Plataforma" {
  component [Aplicaciones Móviles] as MOBILE
  component [Backoffice] as BACKOFFICE
  component [Orchestrator API] as ORCHESTRATOR
  database "Servicios Distribuidos" as SERVICES
}

USER_M --> MOBILE: Usa
ADMIN --> BACKOFFICE: Administra
MOBILE --> ORCHESTRATOR: Solicita datos/operaciones
BACKOFFICE --> ORCHESTRATOR: Configura y monitorea
ORCHESTRATOR --> SERVICES: Coordina
SERVICES --> BACKOFFICE: Métricas
EXT -.-> ORCHESTRATOR: Integraciones

note right of ORCHESTRATOR
  Communication central point
  - Smart routing
  - Load balancing
  - Service discovery
  - Rate limiting
end note

note right of SERVICES
  Autonomous components
  - Isolated databases
  - Independently scalable
  - Async/sync communication
end note

@enduml
